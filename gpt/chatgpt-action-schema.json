{
  "openapi": "3.1.0",
  "info": {
    "title": "Arthas AI Platform",
    "description": "OpenMemory (personal memory system) + Concierge (Sanofi AI assistant)",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://beaver-balloon-isolation-apply.trycloudflare.com"
    }
  ],
  "paths": {
    "/api/v1/memories/search": {
      "post": {
        "operationId": "searchMemories",
        "summary": "Semantic search over memories",
        "description": "Search personal memories by semantic similarity. Only call this for general questions or when user mentions past conversations. Do NOT call this when user explicitly requests Concierge — use conciergeChat/conciergeSearch instead.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query", "user_id"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Natural language search query"
                  },
                  "user_id": {
                    "type": "string",
                    "default": "arthaszeng"
                  },
                  "limit": {
                    "type": "integer",
                    "default": 10,
                    "description": "Max results to return"
                  },
                  "threshold": {
                    "type": "number",
                    "default": 0.0,
                    "description": "Minimum similarity score (0.0 - 1.0)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/MemoryResult"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/memories/": {
      "post": {
        "operationId": "createMemory",
        "summary": "Create a new memory",
        "description": "Store a new memory. Call this when the user shares preferences, decisions, facts, or asks you to remember something.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text", "user_id"],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Memory content — use complete Chinese sentences with full context"
                  },
                  "user_id": {
                    "type": "string",
                    "default": "arthaszeng"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Memory created"
          }
        }
      },
      "get": {
        "operationId": "listMemories",
        "summary": "List all memories",
        "description": "Retrieve a paginated list of all stored memories.",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "default": "arthaszeng" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "size",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated memory list"
          }
        }
      }
    },
    "/api/v1/memories/{memory_id}": {
      "get": {
        "operationId": "getMemory",
        "summary": "Get a specific memory by ID",
        "parameters": [
          {
            "name": "memory_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Memory details"
          }
        }
      },
      "put": {
        "operationId": "updateMemory",
        "summary": "Update a memory's content",
        "parameters": [
          {
            "name": "memory_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["memory_content", "user_id"],
                "properties": {
                  "memory_content": {
                    "type": "string"
                  },
                  "user_id": {
                    "type": "string",
                    "default": "arthaszeng"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Memory updated"
          }
        }
      }
    },
    "/concierge-mcp/api/chat": {
      "post": {
        "operationId": "conciergeChat",
        "summary": "Chat with Sanofi Concierge AI",
        "description": "Send a message to the Sanofi Concierge AI. MUST use this (not searchMemories) when user says 'concierge', 'Concierge', or asks about Sanofi internal topics like schedules, IT support, policies, OneSupport, SharePoint. Requires an active Concierge session.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message"],
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "The message to send to Concierge AI"
                  },
                  "thread_id": {
                    "type": "string",
                    "default": "",
                    "description": "Thread ID for multi-turn conversations. Leave empty for new conversation."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Concierge response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": { "type": "string" },
                    "thread_id": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "No active Concierge session" },
          "502": { "description": "Concierge upstream error" }
        }
      }
    },
    "/concierge-mcp/api/search": {
      "post": {
        "operationId": "conciergeSearch",
        "summary": "Search Sanofi knowledge base",
        "description": "Search Sanofi internal resources (OneSupport, SharePoint, QualiPSO, etc.) via Concierge AI. Use this when user wants to search company knowledge base. Do NOT use searchMemories for Sanofi-related queries.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Search query for Sanofi internal knowledge base"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": { "type": "string" },
                    "query": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "No active Concierge session" },
          "502": { "description": "Concierge upstream error" }
        }
      }
    },
    "/concierge-mcp/auth/status": {
      "get": {
        "operationId": "conciergeAuthStatus",
        "summary": "Check Concierge auth status",
        "description": "Check if there is an active Concierge session. If not connected, user must authenticate via Chrome extension first.",
        "responses": {
          "200": {
            "description": "Auth status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "connected": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MemoryResult": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "memory": { "type": "string" },
          "score": { "type": "number" },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string", "nullable": true }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [
    { "ApiKeyAuth": [] }
  ]
}
