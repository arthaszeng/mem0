{
  "openapi": "3.1.0",
  "info": {
    "title": "Arthas AI Platform (Private)",
    "description": "Memverse (personal memory system) + Concierge (Sanofi AI assistant) — private use only",
    "version": "2.4.0"
  },
  "servers": [
    {
      "url": "https://arthaszeng.top"
    }
  ],
  "paths": {
    "/auth/me": {
      "get": {
        "operationId": "getMyProfile",
        "summary": "Get current user profile",
        "description": "Returns the authenticated user's profile including username. MUST be called at the start of every new conversation to obtain the user_id for subsequent memory API calls.",
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "description": "Internal user ID (UUID)" },
                    "username": { "type": "string", "description": "Username — use this as user_id in all memory API calls" },
                    "email": { "type": "string", "nullable": true }
                  }
                }
              }
            }
          },
          "401": { "description": "Not authenticated" }
        }
      }
    },
    "/api/v1/memories/search": {
      "post": {
        "operationId": "searchMemories",
        "summary": "Semantic search over memories",
        "description": "Search personal memories by semantic similarity. Only call this for general questions or when user mentions past conversations. Do NOT call this when user explicitly requests Concierge — use conciergeChat/conciergeSearch instead.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query", "user_id"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Natural language search query"
                  },
                  "user_id": {
                    "type": "string",
                    "description": "User identifier — use the username returned by getMyProfile"
                  },
                  "limit": {
                    "type": "integer",
                    "default": 10,
                    "description": "Max results to return"
                  },
                  "threshold": {
                    "type": "number",
                    "default": 0.0,
                    "description": "Minimum similarity score (0.0 - 1.0)"
                  },
                  "categories": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Filter by category names"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/MemoryResult"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/memories/": {
      "post": {
        "operationId": "createMemory",
        "summary": "Create a new memory",
        "description": "Store a new memory. Call this when the user shares preferences, decisions, facts, or asks you to remember something.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text", "user_id"],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Memory content — use complete Chinese sentences with full context"
                  },
                  "user_id": {
                    "type": "string",
                    "description": "User identifier — use the username returned by getMyProfile"
                  },
                  "expires_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO datetime when this memory expires (optional)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Memory created"
          }
        }
      },
      "get": {
        "operationId": "listMemories",
        "summary": "List all memories",
        "description": "Retrieve a paginated list of all stored memories.",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "User identifier — use the username returned by getMyProfile"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "size",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated memory list"
          }
        }
      }
    },
    "/api/v1/memories/{memory_id}": {
      "get": {
        "operationId": "getMemory",
        "summary": "Get a specific memory by ID",
        "parameters": [
          {
            "name": "memory_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Memory details"
          }
        }
      },
      "put": {
        "operationId": "updateMemory",
        "summary": "Update a memory's content",
        "parameters": [
          {
            "name": "memory_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["memory_content", "user_id"],
                "properties": {
                  "memory_content": {
                    "type": "string"
                  },
                  "user_id": {
                    "type": "string",
                    "description": "User identifier — use the username returned by getMyProfile"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Memory updated"
          }
        }
      }
    },
    "/api/v1/memories/export": {
      "post": {
        "operationId": "exportMemories",
        "summary": "Export memories grouped by category",
        "description": "Export all or filtered memories in JSON or text format, grouped by category.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "format": { "type": "string", "enum": ["json", "text"], "default": "json" },
                  "categories": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Exported memories" } }
      }
    },
    "/api/v1/memories/actions/restore": {
      "post": {
        "operationId": "restoreMemories",
        "summary": "Restore archived memories",
        "description": "Restore one or more archived memories back to active state.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["memory_ids"],
                "properties": {
                  "memory_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Memories restored" } }
      }
    },
    "/concierge-mcp/api/chat": {
      "post": {
        "operationId": "conciergeChat",
        "summary": "Chat with Sanofi Concierge AI",
        "description": "Send a message to the Sanofi Concierge AI. MUST use this (not searchMemories) when user says 'concierge', 'Concierge', or asks about Sanofi internal topics like schedules, IT support, policies, OneSupport, SharePoint. Requires an active Concierge session.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message"],
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "The message to send to Concierge AI"
                  },
                  "thread_id": {
                    "type": "string",
                    "default": "",
                    "description": "Thread ID for multi-turn conversations. Leave empty for new conversation."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Concierge response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": { "type": "string" },
                    "thread_id": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "No active Concierge session" },
          "502": { "description": "Concierge upstream error" }
        }
      }
    },
    "/concierge-mcp/api/search": {
      "post": {
        "operationId": "conciergeSearch",
        "summary": "Search Sanofi knowledge base",
        "description": "Search Sanofi internal resources (OneSupport, SharePoint, QualiPSO, etc.) via Concierge AI. Use this when user wants to search company knowledge base. Do NOT use searchMemories for Sanofi-related queries.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Search query for Sanofi internal knowledge base"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": { "type": "string" },
                    "query": { "type": "string" }
                  }
                }
              }
            }
          },
          "401": { "description": "No active Concierge session" },
          "502": { "description": "Concierge upstream error" }
        }
      }
    },
    "/api/v1/entities/graph": {
      "get": {
        "operationId": "getKnowledgeGraph",
        "summary": "Get knowledge graph data",
        "description": "Returns entity nodes and relationship edges for visualization. Entities are extracted from memories automatically.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 50, "maximum": 200 },
            "description": "Maximum number of entity nodes to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Graph data with nodes and edges",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "nodes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string" },
                          "type": { "type": "string" },
                          "memory_count": { "type": "integer" }
                        }
                      }
                    },
                    "edges": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "source": { "type": "string" },
                          "target": { "type": "string" },
                          "relation": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/concierge-mcp/auth/status": {
      "get": {
        "operationId": "conciergeAuthStatus",
        "summary": "Check Concierge auth status",
        "description": "Check if there is an active Concierge session. If not connected, user must authenticate via Chrome extension first.",
        "responses": {
          "200": {
            "description": "Auth status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "connected": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/memories/stats/insights": {
      "get": {
        "operationId": "getMemoryInsights",
        "summary": "Get intelligent insights about stored memories",
        "description": "Returns LLM-generated user profile summary, trending topics analysis (rising/stable/declining), and knowledge category coverage.",
        "parameters": [
          {
            "name": "refresh",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false },
            "description": "Force regenerate user profile from LLM"
          }
        ],
        "responses": {
          "200": {
            "description": "Memory insights",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user_profile": {
                      "type": "object",
                      "nullable": true,
                      "properties": {
                        "summary": { "type": "string" },
                        "generated_at": { "type": "string" }
                      }
                    },
                    "topic_trends": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "topic": { "type": "string" },
                          "trend": { "type": "string", "enum": ["rising", "stable", "declining"] },
                          "recent_count": { "type": "integer" },
                          "previous_count": { "type": "integer" }
                        }
                      }
                    },
                    "knowledge_coverage": {
                      "type": "object",
                      "properties": {
                        "total_categories": { "type": "integer" },
                        "total_domains": { "type": "integer" },
                        "top_categories": { "type": "array", "items": { "$ref": "#/components/schemas/CategoryCoverage" } },
                        "sparse_categories": { "type": "array", "items": { "$ref": "#/components/schemas/CategoryCoverage" } },
                        "domain_coverage": { "type": "array", "items": { "$ref": "#/components/schemas/CategoryCoverage" } }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CategoryCoverage": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "count": { "type": "integer" },
          "pct": { "type": "number" }
        }
      },
      "MemoryResult": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "memory": { "type": "string" },
          "score": { "type": "number" },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string", "nullable": true }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    { "BearerAuth": [] }
  ]
}
