{
  "openapi": "3.1.0",
  "info": {
    "title": "Arthas AI Platform API",
    "description": "Arthas's personal AI platform — OpenMemory (memory system) + Concierge (Sanofi AI assistant). Both services share a single Cloudflare Tunnel entry point.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://<tunnel-subdomain>.trycloudflare.com",
      "description": "Cloudflare Tunnel (replace with actual URL from: sudo journalctl -u cloudflared-tunnel | grep trycloudflare)"
    }
  ],
  "paths": {
    "/api/v1/memories/search": {
      "post": {
        "operationId": "searchMemories",
        "summary": "Semantic search over memories",
        "description": "Search memories by semantic similarity. Call this EVERY TIME the user asks a question, to load relevant context from past conversations.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query", "user_id"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Natural language search query"
                  },
                  "user_id": {
                    "type": "string",
                    "default": "arthaszeng"
                  },
                  "limit": {
                    "type": "integer",
                    "default": 10,
                    "description": "Max results to return"
                  },
                  "threshold": {
                    "type": "number",
                    "default": 0.0,
                    "description": "Minimum similarity score (0.0 - 1.0)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/MemoryResult"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/memories/": {
      "post": {
        "operationId": "createMemory",
        "summary": "Create a new memory",
        "description": "Store a new memory. Call this when the user shares preferences, decisions, facts, or asks you to remember something.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text", "user_id"],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Memory content — use complete Chinese sentences with full context"
                  },
                  "user_id": {
                    "type": "string",
                    "default": "arthaszeng"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Memory created"
          }
        }
      },
      "get": {
        "operationId": "listMemories",
        "summary": "List all memories",
        "description": "Retrieve a paginated list of all stored memories.",
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "default": "arthaszeng" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "size",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated memory list"
          }
        }
      }
    },
    "/api/v1/memories/{memory_id}": {
      "get": {
        "operationId": "getMemory",
        "summary": "Get a specific memory by ID",
        "parameters": [
          {
            "name": "memory_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Memory details"
          }
        }
      },
      "put": {
        "operationId": "updateMemory",
        "summary": "Update a memory's content",
        "parameters": [
          {
            "name": "memory_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["memory_content", "user_id"],
                "properties": {
                  "memory_content": {
                    "type": "string"
                  },
                  "user_id": {
                    "type": "string",
                    "default": "arthaszeng"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Memory updated"
          }
        }
      }
    },
    "/concierge-mcp/api/chat": {
      "post": {
        "operationId": "conciergeChat",
        "summary": "Chat with Sanofi Concierge AI",
        "description": "Send a message to the Sanofi Concierge AI (powered by Claude 4 Sonnet). Use this to ask questions about Sanofi internal knowledge, policies, procedures, IT support, or any general topic. Requires an active Concierge session (authenticated via Chrome extension).",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message"],
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "The message to send to Concierge AI"
                  },
                  "thread_id": {
                    "type": "string",
                    "default": "",
                    "description": "Optional thread ID for multi-turn conversations. Leave empty for a new conversation."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Concierge response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "string",
                      "description": "The full text response from Concierge AI"
                    },
                    "thread_id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "No active Concierge session — user must authenticate via Chrome extension first"
          },
          "502": {
            "description": "Concierge upstream error"
          }
        }
      }
    },
    "/concierge-mcp/api/search": {
      "post": {
        "operationId": "conciergeSearch",
        "summary": "Search Sanofi knowledge base via Concierge AI",
        "description": "Search across Sanofi internal resources (OneSupport, SharePoint, QualiPSO, etc.) via Concierge AI. Requires an active Concierge session.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Search query for Sanofi internal knowledge base"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results from Concierge",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "string",
                      "description": "Summarized search results from Concierge AI"
                    },
                    "query": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "No active Concierge session"
          },
          "502": {
            "description": "Concierge upstream error"
          }
        }
      }
    },
    "/concierge-mcp/auth/status": {
      "get": {
        "operationId": "conciergeAuthStatus",
        "summary": "Check Concierge authentication status",
        "description": "Check if there is an active Concierge session. If not connected, the user must authenticate via the Chrome extension before using Concierge chat/search.",
        "security": [],
        "responses": {
          "200": {
            "description": "Authentication status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "connected": {
                      "type": "boolean",
                      "description": "true if an active Concierge session exists"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MemoryResult": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "memory": { "type": "string" },
          "score": { "type": "number" },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string", "nullable": true }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Required for OpenMemory API endpoints only. Concierge endpoints use session-based auth."
      }
    }
  },
  "security": [
    { "ApiKeyAuth": [] }
  ]
}
