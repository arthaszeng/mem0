{
  "openapi": "3.1.0",
  "info": {
    "title": "Memverse",
    "description": "Personal AI memory system — store, search, and manage your memories across AI clients",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://arthaszeng.top"
    }
  ],
  "paths": {
    "/auth/me": {
      "get": {
        "operationId": "getMyProfile",
        "summary": "Get current user profile",
        "description": "Returns the authenticated user's profile including username. MUST be called at the start of every new conversation to obtain the user_id for subsequent memory API calls.",
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "description": "Internal user ID (UUID)" },
                    "username": { "type": "string", "description": "Username — use this as user_id in all memory API calls" },
                    "email": { "type": "string", "nullable": true }
                  }
                }
              }
            }
          },
          "401": { "description": "Not authenticated" }
        }
      }
    },
    "/api/v1/memories/search": {
      "post": {
        "operationId": "searchMemories",
        "summary": "Semantic search over memories",
        "description": "Search personal memories by semantic similarity. Use this to recall past conversations, preferences, decisions, or any stored knowledge.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query", "user_id"],
                "properties": {
                  "query": { "type": "string", "description": "Natural language search query" },
                  "user_id": { "type": "string", "description": "User identifier — use the username returned by getMyProfile" },
                  "limit": { "type": "integer", "default": 10, "description": "Max results to return" },
                  "threshold": { "type": "number", "default": 0.0, "description": "Minimum similarity score (0.0 - 1.0)" },
                  "categories": { "type": "array", "items": { "type": "string" }, "description": "Filter by category names" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/MemoryResult" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/memories/": {
      "post": {
        "operationId": "createMemory",
        "summary": "Create a new memory",
        "description": "Store a new memory. Call this when the user shares preferences, decisions, facts, or asks you to remember something.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text", "user_id"],
                "properties": {
                  "text": { "type": "string", "description": "Memory content — use complete sentences with full context" },
                  "user_id": { "type": "string", "description": "User identifier — use the username returned by getMyProfile" },
                  "expires_at": { "type": "string", "format": "date-time", "description": "ISO datetime when this memory expires" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Memory created" }
        }
      },
      "get": {
        "operationId": "listMemories",
        "summary": "List all memories",
        "description": "Retrieve a paginated list of all stored memories.",
        "parameters": [
          { "name": "user_id", "in": "query", "required": true, "schema": { "type": "string" }, "description": "User identifier — use the username returned by getMyProfile" },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "size", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "Paginated memory list" }
        }
      }
    },
    "/api/v1/memories/{memory_id}": {
      "get": {
        "operationId": "getMemory",
        "summary": "Get a specific memory by ID",
        "parameters": [
          { "name": "memory_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Memory details" }
        }
      },
      "put": {
        "operationId": "updateMemory",
        "summary": "Update a memory's content",
        "parameters": [
          { "name": "memory_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["memory_content", "user_id"],
                "properties": {
                  "memory_content": { "type": "string" },
                  "user_id": { "type": "string", "description": "User identifier — use the username returned by getMyProfile" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Memory updated" }
        }
      },
      "delete": {
        "operationId": "deleteMemory",
        "summary": "Delete a memory",
        "parameters": [
          { "name": "memory_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Memory deleted" }
        }
      }
    },
    "/api/v1/memories/export": {
      "post": {
        "operationId": "exportMemories",
        "summary": "Export memories grouped by category",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "format": { "type": "string", "enum": ["json", "text"], "default": "json" },
                  "categories": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Exported memories" } }
      }
    },
    "/api/v1/memories/actions/restore": {
      "post": {
        "operationId": "restoreMemories",
        "summary": "Restore archived memories",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["memory_ids"],
                "properties": {
                  "memory_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Memories restored" } }
      }
    },
    "/api/v1/memories/stats/insights": {
      "get": {
        "operationId": "getMemoryInsights",
        "summary": "Get intelligent insights about stored memories",
        "description": "Returns LLM-generated user profile summary, trending topics analysis, and knowledge category coverage.",
        "parameters": [
          { "name": "refresh", "in": "query", "required": false, "schema": { "type": "boolean", "default": false }, "description": "Force regenerate user profile from LLM" }
        ],
        "responses": {
          "200": {
            "description": "Memory insights",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user_profile": {
                      "type": "object",
                      "nullable": true,
                      "properties": {
                        "summary": { "type": "string" },
                        "generated_at": { "type": "string" }
                      }
                    },
                    "topic_trends": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "topic": { "type": "string" },
                          "trend": { "type": "string", "enum": ["rising", "stable", "declining"] },
                          "recent_count": { "type": "integer" },
                          "previous_count": { "type": "integer" }
                        }
                      }
                    },
                    "knowledge_coverage": {
                      "type": "object",
                      "properties": {
                        "total_categories": { "type": "integer" },
                        "total_domains": { "type": "integer" },
                        "top_categories": { "type": "array", "items": { "$ref": "#/components/schemas/CategoryCoverage" } },
                        "sparse_categories": { "type": "array", "items": { "$ref": "#/components/schemas/CategoryCoverage" } },
                        "domain_coverage": { "type": "array", "items": { "$ref": "#/components/schemas/CategoryCoverage" } }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CategoryCoverage": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "count": { "type": "integer" },
          "pct": { "type": "number" }
        }
      },
      "MemoryResult": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "memory": { "type": "string" },
          "score": { "type": "number" },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string", "nullable": true }
        }
      }
    },
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://arthaszeng.top/auth/authorize",
            "tokenUrl": "https://arthaszeng.top/auth/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    { "OAuth2": [] }
  ]
}
