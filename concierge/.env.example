# MCP Server config
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8766
MCP_SERVER_URL=http://localhost:8766

# Dev mode: SSE accepts unauthenticated connections (cookie sync still required for tools)
MCP_DEV_MODE=true

# JWT secret for signing MCP OAuth tokens
JWT_SECRET=change-me-to-a-random-secret

# Concierge target
CONCIERGE_DOMAIN=concierge.sanofi.com
CONCIERGE_BASE_URL=https://concierge.sanofi.com

# Chrome extension ID (filled after installing the extension)
CHROME_EXTENSION_ID=
