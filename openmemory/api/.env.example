# For non-Docker local development only (running uvicorn directly).
# Docker deployments use the top-level openmemory/.env instead.

MEM0_USER=arthaszeng
OPENAI_API_KEY=sk-xxx

# Categorization provider: "ollama" (local) or "openai" (cloud)
CATEGORIZATION_PROVIDER=ollama
# Model auto-selected per provider: qwen2.5:7b (ollama) / gpt-4o-mini (openai)
# Uncomment to override:
# CATEGORIZATION_MODEL=qwen2.5:7b

# Optional: override auto-detected Ollama URL (defaults to host.docker.internal:11434 in Docker)
# CATEGORIZATION_OLLAMA_BASE_URL=http://host.docker.internal:11434
