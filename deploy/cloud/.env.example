# ========== Version (updated by deploy script) ==========
APP_VERSION=latest

# ========== Shared ==========
MEMVERSE_USER=arthaszeng
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_BASE_URL=https://millionengine.com/v1

# ========== Memverse UI ==========
NEXT_PUBLIC_API_URL=https://arthaszeng.top

# ========== Memverse MCP Backend ==========
QDRANT_HOST=memverse-store
QDRANT_PORT=6333
CATEGORIZATION_PROVIDER=openai
FORCE_OPENAI=true

# ========== CORS ==========
CORS_ALLOWED_ORIGINS=https://arthaszeng.top,http://arthaszeng.top

# ========== Auth Service ==========
INIT_ADMIN_USER=arthaszeng
INIT_ADMIN_PASSWORD=<your-password>
AUTH_BASE_URL=https://arthaszeng.top/auth
DATA_DIR=/data

# ========== Concierge MCP ==========
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8767
MCP_DEV_MODE=false
CONCIERGE_BASE_URL=https://concierge.sanofi.com
MEMVERSE_URL=http://memverse-mcp:8765

# ========== Lobe Chat & Agent ==========
LOBE_ACCESS_CODE=<your-access-code>
LLM_MODEL=qwen-plus
